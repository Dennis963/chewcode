{
  "name": "chewcode_bridge",
  "version": "1.1.0",
  "description": "Lightweight bridge for ChewCode mobile clients",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "package:deb": "dpkg-buildpackage -us -uc -b"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "fastify": "^5.2.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.10",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
